POSTGRES_DB=pinocchio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# If you already have another Postgres server, you can set a full URL instead.
# POSTGRES_URL=postgres://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres
# DATABASE_URL is also supported for compatibility, but POSTGRES_URL wins when both exist.
# DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/pinocchio
# Local docker Postgres does not use SSL.
POSTGRES_SSL=disable
ADMIN_CODE=replace-with-a-strong-admin-code
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
BLOB_READ_WRITE_TOKEN=replace-with-your-vercel-blob-token
