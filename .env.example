POSTGRES_DB=pinocchio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
# Docker compose builds POSTGRES_URL from the POSTGRES_* values above.
# If you run the app without Docker, use localhost instead.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/pinocchio
# Local docker Postgres does not use SSL.
POSTGRES_SSL=disable
ADMIN_CODE=replace-with-a-strong-admin-code
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
BLOB_READ_WRITE_TOKEN=replace-with-your-vercel-blob-token
