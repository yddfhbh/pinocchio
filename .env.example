# Option A: use the Postgres container from this docker-compose stack.
# In that mode the app talks to the internal Docker hostname `db`
# and uses the `pinocchio` database by default.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=pinocchio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-your-db-password

# Option B: use a different Postgres instance instead.
# Uncomment POSTGRES_URL and point it at the database you actually want the app to read.
# POSTGRES_URL=postgres://postgres:YOUR_PASSWORD@134.185.101.15:5432/postgres
# DATABASE_URL is also supported for compatibility, but POSTGRES_URL wins when both exist.

POSTGRES_SSL=disable
# Set ADMIN_CODE to the only admin login code you want to allow.
# ADMIN_SESSION_SECRET is only used to sign the admin session cookie.
ADMIN_CODE=pusanpino
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
BLOB_READ_WRITE_TOKEN=replace-with-your-vercel-blob-token
APP_DOMAIN=pusanpino.kro.kr
APP_DOMAIN_ALIASES=
LETSENCRYPT_EMAIL=replace-with-your-email@example.com
VITE_ALLOWED_HOSTS=pusanpino.kro.kr,.pusanpino.kro.kr,localhost,127.0.0.1
