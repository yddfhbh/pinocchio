# For docker compose -> host Postgres defaults
POSTGRES_URL=postgres://postgres:YOUR_PASSWORD@host.docker.internal:5432/postgres
# If you run the app without Docker, use localhost instead
# DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/postgres
# Use "require" in production. Set "disable" only for a trusted local database.
POSTGRES_SSL=require
ADMIN_CODE=replace-with-a-strong-admin-code
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
BLOB_READ_WRITE_TOKEN=replace-with-your-vercel-blob-token
